# Copy this file to `.env` and edit values for your environment.
NTRIP_USERNAME=your_username
NTRIP_PASSWORD=your_password
VEHICLE_ID=A0
TEAM_NAME="ABC"
ROS_DOMAIN_ID=1
# Must be an absolute path because colcon --symlink-install can contain absolute symlinks.
RACING_KART_INTERFACE_DIR=/home/tier4/racing_kart_interface
# Host identity, auto-filled by `./setup.bash env` / `make` (id -u, id -g, dialout GID for /dev/vcu,/dev/gnss, input GID for /dev/input/event*).
HOST_UID=1000
HOST_GID=1000
HOST_GID_DIALOUT=20
HOST_GID_INPUT=104

# Compose overlays (docker compose reads COMPOSE_FILE from .env). Pick "One" line:
COMPOSE_FILE=docker-compose.yml
# COMPOSE_FILE=docker-compose.yml:docker-compose.sound.yml
# COMPOSE_FILE=docker-compose.yml:docker-compose.gpu.yml:docker-compose.sound.yml
